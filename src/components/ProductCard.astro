---
const { nombre, precio, descripcion = '', imagen = '', categoria = '' } = Astro.props;
---

<article
  class="product-card group bg-card rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
  data-nombre={nombre}
  data-precio={precio}
  data-imagen={imagen}
>
  <div class="relative h-44 overflow-hidden bg-border/50">
    {imagen ? (
      <img
        src={imagen}
        alt={nombre}
        class="product-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        loading="lazy"
        onerror="this.style.opacity='0'"
      />
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    <span class="absolute top-2.5 right-2.5 bg-white/95 backdrop-blur text-text font-bold text-sm px-3 py-1 rounded-full shadow-sm">
      ${precio}
    </span>
    {categoria && (
      <span class="absolute bottom-2.5 left-2.5 bg-text/80 backdrop-blur text-white text-[10px] uppercase tracking-wider font-semibold px-2 py-1 rounded-md">
        {categoria}
      </span>
    )}
  </div>

  <div class="p-4 flex flex-col">
    <h3 class="font-display font-bold text-lg text-text leading-tight mb-1">{nombre}</h3>
    {descripcion ? (
      <p class="text-text-muted text-xs line-clamp-2 mb-4 min-h-[2rem]">{descripcion}</p>
    ) : (
      <div class="min-h-[2rem] mb-4"></div>
    )}

    <div class="add-control mt-auto">
      <button
        class="add-btn w-full bg-brand text-white py-2.5 rounded-xl font-semibold text-sm hover:bg-brand-dark active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-brand/20 shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        Agregar
      </button>
    </div>
  </div>
</article>

<script>
  import { cartItems, addToCart, incrementQuantity, decrementQuantity } from '../store/cart';

  function renderControl(card, item) {
    const container = card.querySelector('.add-control');
    const nombre = card.dataset.nombre;
    const precio = Number(card.dataset.precio);
    const imagen = card.dataset.imagen || '';

    if (item && item.cantidad > 0) {
      container.innerHTML = `
        <div class="flex items-center gap-2 bg-border/40 rounded-xl p-1.5">
          <button class="dec-qty w-10 h-9 rounded-lg bg-white text-text font-bold shadow-sm hover:bg-brand/10 active:scale-95 transition-all flex items-center justify-center">−</button>
          <span class="flex-1 text-center font-bold text-text">${item.cantidad}</span>
          <button class="inc-qty w-10 h-9 rounded-lg bg-brand text-white font-bold shadow-sm hover:bg-brand-dark active:scale-95 transition-all flex items-center justify-center">+</button>
        </div>
      `;
      container.querySelector('.dec-qty').addEventListener('click', () => decrementQuantity(nombre));
      container.querySelector('.inc-qty').addEventListener('click', () => incrementQuantity(nombre));
    } else {
      container.innerHTML = `
        <button class="add-btn w-full bg-brand text-white py-2.5 rounded-xl font-semibold text-sm hover:bg-brand-dark active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-brand/20 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
          Agregar
        </button>
      `;
      container.querySelector('.add-btn').addEventListener('click', () => addToCart({ nombre, precio, imagen }));
    }
  }

  function syncCards(items) {
    document.querySelectorAll('.product-card').forEach((card) => {
      const nombre = card.dataset.nombre;
      renderControl(card, items[nombre]);
    });
  }

  cartItems.subscribe(syncCards);
</script>
