---
const { nombre, precio, descripcion = '', imagen = '', categoria = '' } = Astro.props;
---

<article
  class="product-card group relative flex sm:flex-col bg-card rounded-xl sm:rounded-2xl overflow-hidden border border-border shadow-sm hover:shadow-md transition-all cursor-pointer"
  data-nombre={nombre}
  data-precio={precio}
  data-descripcion={descripcion}
  data-imagen={imagen}
  data-categoria={categoria}
>
  <!-- Imagen: cuadrada en móvil, vertical en desktop -->
  <div class="relative w-24 h-24 sm:w-full sm:h-44 shrink-0 overflow-hidden bg-border/50">
    {imagen ? (
      <img
        src={imagen}
        alt={nombre}
        class="product-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        loading="lazy"
        onerror="this.style.opacity='0'"
      />
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    <span class="hidden sm:absolute sm:top-2.5 sm:right-2.5 sm:bg-white/95 sm:backdrop-blur sm:text-text sm:font-bold sm:text-sm sm:px-3 sm:py-1 sm:rounded-full sm:shadow-sm">
      ${precio}
    </span>
  </div>

  <!-- Contenido -->
  <div class="flex-1 flex flex-col justify-between p-3 sm:p-4 min-w-0">
    <div class="min-w-0">
      <h3 class="font-display font-bold text-base sm:text-lg text-text leading-tight truncate sm:whitespace-normal">{nombre}</h3>
      <p class="text-text-muted text-xs line-clamp-1 sm:line-clamp-2 mt-0.5 sm:mt-1">{descripcion}</p>
    </div>

    <div class="flex items-center justify-between mt-2 sm:mt-4">
      <span class="text-brand font-bold text-sm sm:text-lg">${precio}</span>

      <!-- Botón + rápido solo en móvil -->
      <button
        class="quick-add sm:hidden w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center shadow-sm hover:bg-brand-dark active:scale-90 transition-all"
        aria-label="Agregar rápido"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
      </button>

      <!-- Controles desktop -->
      <div class="add-control hidden sm:block">
        <button
          class="add-btn w-full bg-brand text-white px-5 py-2 rounded-xl font-semibold text-sm hover:bg-brand-dark active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-brand/20 shadow-sm"
        >
          Agregar
        </button>
      </div>
    </div>
  </div>
</article>

<script>
  import { cartItems, addToCart, incrementQuantity, decrementQuantity } from '../store/cart';

  function renderControl(card, item) {
    const container = card.querySelector('.add-control');
    if (!container) return;
    const nombre = card.dataset.nombre;
    const precio = Number(card.dataset.precio);
    const imagen = card.dataset.imagen || '';

    if (item && item.cantidad > 0) {
      container.innerHTML = `
        <div class="flex items-center gap-2 bg-border/40 rounded-xl p-1">
          <button class="dec-qty w-8 h-8 rounded-lg bg-white text-text font-bold shadow-sm hover:bg-brand/10 active:scale-95 transition-all flex items-center justify-center">−</button>
          <span class="w-5 text-center font-bold text-text">${item.cantidad}</span>
          <button class="inc-qty w-8 h-8 rounded-lg bg-brand text-white font-bold shadow-sm hover:bg-brand-dark active:scale-95 transition-all flex items-center justify-center">+</button>
        </div>
      `;
      container.querySelector('.dec-qty').addEventListener('click', (e) => {
        e.stopPropagation();
        decrementQuantity(nombre);
      });
      container.querySelector('.inc-qty').addEventListener('click', (e) => {
        e.stopPropagation();
        incrementQuantity(nombre);
      });
    } else {
      container.innerHTML = `
        <button class="add-btn w-full bg-brand text-white px-5 py-2 rounded-xl font-semibold text-sm hover:bg-brand-dark active:scale-[0.98] transition-all flex items-center justify-center gap-2 shadow-brand/20 shadow-sm">
          Agregar
        </button>
      `;
      container.querySelector('.add-btn').addEventListener('click', (e) => {
        e.stopPropagation();
        addToCart({ nombre, precio, imagen });
      });
    }
  }

  function syncCards(items) {
    document.querySelectorAll('.product-card').forEach((card) => {
      const nombre = card.dataset.nombre;
      renderControl(card, items[nombre]);
    });
  }

  cartItems.subscribe(syncCards);

  // Click en la card abre el modal (excepto en botones de cantidad o + rápido)
  document.querySelectorAll('.product-card').forEach((card) => {
    const quickAdd = card.querySelector('.quick-add');

    quickAdd?.addEventListener('click', (e) => {
      e.stopPropagation();
      const nombre = card.dataset.nombre;
      const precio = Number(card.dataset.precio);
      const imagen = card.dataset.imagen || '';
      addToCart({ nombre, precio, imagen });
    });

    card.addEventListener('click', (e) => {
      if (e.target.closest('.add-control') || e.target.closest('.quick-add')) return;

      window.dispatchEvent(
        new CustomEvent('open-product-modal', {
          detail: {
            nombre: card.dataset.nombre,
            precio: Number(card.dataset.precio),
            descripcion: card.dataset.descripcion,
            imagen: card.dataset.imagen,
            categoria: card.dataset.categoria,
          },
        })
      );
    });
  });
</script>
