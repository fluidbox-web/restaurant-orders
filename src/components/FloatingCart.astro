---
---

<!-- Floating Cart Pill -->
<button
  id="cart-toggle"
  class="fixed bottom-5 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-sm md:w-auto md:bottom-8 md:right-8 md:left-auto md:translate-x-0 z-50 bg-text text-white pl-4 pr-5 py-3.5 rounded-full shadow-2xl shadow-text/20 backdrop-blur-md hover:brightness-110 active:scale-95 transition-all duration-300 flex items-center justify-center gap-3 cursor-pointer"
  aria-label="Abrir carrito"
>
  <div class="relative">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
    <span id="cart-badge" class="absolute -top-2.5 -right-2.5 bg-brand text-white text-[10px] font-bold min-w-[18px] h-[18px] rounded-full flex items-center justify-center px-1 hidden">0</span>
  </div>
  <span class="font-semibold text-sm">Tu pedido</span>
  <span id="cart-pill-total" class="bg-white/15 px-2 py-0.5 rounded-full text-sm font-bold">$0</span>
</button>

<!-- Drawer -->
<div id="cart-modal" class="fixed inset-0 z-[55] pointer-events-none">
  <div id="cart-backdrop" class="absolute inset-0 bg-text/30 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>

  <div
    id="cart-panel"
    class="absolute left-0 right-0 bottom-0 md:top-0 md:right-0 md:left-auto md:bottom-0 md:w-[420px] h-[85vh] md:h-full bg-card rounded-t-3xl md:rounded-none shadow-2xl flex flex-col translate-y-full md:translate-y-0 md:translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]"
  >
    <div class="flex items-center justify-between p-5 border-b border-border shrink-0">
      <div>
        <h2 class="font-display text-2xl font-bold text-text">Tu pedido</h2>
        <p id="cart-subtitle" class="text-text-muted text-xs mt-0.5">0 artículos</p>
      </div>
      <button id="cart-close" class="w-10 h-10 rounded-full bg-border/50 text-text hover:bg-border transition-colors cursor-pointer flex items-center justify-center" aria-label="Cerrar carrito">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
      </button>
    </div>

    <div id="cart-items" class="flex-1 overflow-y-auto p-5 space-y-3">
      <div id="cart-empty" class="flex flex-col items-center justify-center h-full text-center py-10">
        <div class="w-20 h-20 rounded-full bg-border/40 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        </div>
        <p class="text-text font-semibold">Tu carrito está vacío</p>
        <p class="text-text-muted text-sm mt-1 max-w-[220px]">Explora el menú y agrega algo delicioso.</p>
      </div>
    </div>

    <div id="cart-footer" class="hidden border-t border-border p-5 bg-cream shrink-0 rounded-t-3xl md:rounded-none">
      <div class="flex justify-between items-end mb-4">
        <span class="text-text-muted text-sm">Total a pagar</span>
        <span id="cart-total" class="text-text font-display font-bold text-3xl">$0</span>
      </div>

      <div class="space-y-3">
        <div>
          <label for="cart-name" class="text-text text-xs font-semibold mb-1.5 block">Nombre y mesa</label>
          <input
            id="cart-name"
            type="text"
            placeholder="Ej. Juan - Mesa 5"
            class="w-full p-3.5 rounded-xl border border-border bg-white text-text placeholder:text-text-muted/50 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/10 transition-all text-sm"
          />
        </div>

        <div>
          <label id="cart-notes-label" for="cart-notes" class="text-text text-xs font-semibold mb-1.5 block">Notas adicionales</label>
          <textarea
            id="cart-notes"
            rows="2"
            placeholder="Sin cebolla, extra salsa..."
            class="w-full p-3.5 rounded-xl border border-border bg-white text-text placeholder:text-text-muted/50 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/10 transition-all text-sm resize-none"
          ></textarea>
        </div>

        <label class="flex items-center gap-3 cursor-pointer">
          <input
            id="cart-delivery"
            type="checkbox"
            class="w-5 h-5 rounded border-border text-brand focus:ring-brand cursor-pointer"
          />
          <span class="text-text text-sm font-medium">Servicio a domicilio</span>
        </label>

        <div id="cart-address-wrapper" class="hidden">
          <label for="cart-address" class="text-text text-xs font-semibold mb-1.5 block">Dirección de entrega</label>
          <textarea
            id="cart-address"
            rows="2"
            placeholder="Calle, número, colonia, referencias..."
            class="w-full p-3.5 rounded-xl border border-border bg-white text-text placeholder:text-text-muted/50 focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/10 transition-all text-sm resize-none"
          ></textarea>
        </div>

        <button id="cart-send" class="w-full bg-success text-white py-4 rounded-xl font-bold text-base hover:brightness-110 active:scale-[0.98] transition-all cursor-pointer flex items-center justify-center gap-2 shadow-lg shadow-success/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Enviar pedido por WhatsApp
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    cartItems,
    totalItems,
    totalPrice,
    removeFromCart,
    incrementQuantity,
    decrementQuantity,
  } from '../store/cart';
  import gsap from 'gsap';

  const toggle = document.getElementById('cart-toggle');
  const modal = document.getElementById('cart-modal');
  const panel = document.getElementById('cart-panel');
  const backdrop = document.getElementById('cart-backdrop');
  const close = document.getElementById('cart-close');
  const badge = document.getElementById('cart-badge');
  const pillTotal = document.getElementById('cart-pill-total');
  const itemsContainer = document.getElementById('cart-items');
  const emptyState = document.getElementById('cart-empty');
  const footer = document.getElementById('cart-footer');
  const totalEl = document.getElementById('cart-total');
  const subtitle = document.getElementById('cart-subtitle');
  const sendBtn = document.getElementById('cart-send');
  const nameInput = document.getElementById('cart-name');
  const notesInput = document.getElementById('cart-notes');
  const deliveryCheckbox = document.getElementById('cart-delivery');
  const addressWrapper = document.getElementById('cart-address-wrapper');
  const addressInput = document.getElementById('cart-address');

  let isOpen = false;

  deliveryCheckbox.addEventListener('change', () => {
    if (deliveryCheckbox.checked) {
      addressWrapper.classList.remove('hidden');
      setTimeout(() => addressInput.focus(), 100);
    } else {
      addressWrapper.classList.add('hidden');
      addressInput.value = '';
    }
  });

  function openCart() {
    isOpen = true;
    modal.classList.remove('pointer-events-none');
    backdrop.classList.remove('opacity-0');
    backdrop.classList.add('opacity-100');
    panel.classList.remove('translate-y-full', 'md:translate-x-full');
    panel.classList.add('translate-y-0', 'md:translate-x-0');
    document.body.style.overflow = 'hidden';
    setTimeout(() => nameInput?.focus(), 350);
  }

  function closeCart() {
    isOpen = false;
    backdrop.classList.remove('opacity-100');
    backdrop.classList.add('opacity-0');
    panel.classList.add('translate-y-full', 'md:translate-x-full');
    panel.classList.remove('translate-y-0', 'md:translate-x-0');
    document.body.style.overflow = '';
    setTimeout(() => modal.classList.add('pointer-events-none'), 300);
  }

  toggle.addEventListener('click', openCart);
  close.addEventListener('click', closeCart);
  backdrop.addEventListener('click', closeCart);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeCart();
  });

  function renderCartItems(items) {
    const entries = Object.values(items);

    if (entries.length === 0) {
      emptyState.classList.remove('hidden');
      footer.classList.add('hidden');
      itemsContainer.querySelectorAll('.cart-item-row').forEach((el) => el.remove());
      return;
    }

    emptyState.classList.add('hidden');
    footer.classList.remove('hidden');

    const existingIds = new Set(entries.map((e) => `cart-item-${e.nombre.replace(/\s+/g, '-')}`));
    itemsContainer.querySelectorAll('.cart-item-row').forEach((el) => {
      if (!existingIds.has(el.id)) el.remove();
    });

    entries.forEach((item) => {
      const id = `cart-item-${item.nombre.replace(/\s+/g, '-')}`;
      let row = document.getElementById(id);

      if (!row) {
        row = document.createElement('div');
        row.id = id;
        row.className =
          'cart-item-row flex items-center gap-3 bg-white rounded-2xl p-3 border border-border shadow-sm';
        const thumb = item.imagen
          ? `<img src="${item.imagen}" alt="${item.nombre}" class="w-12 h-12 rounded-xl object-cover shrink-0" loading="lazy" />`
          : `<div class="w-12 h-12 rounded-xl bg-border/40 flex items-center justify-center shrink-0 text-lg">🍽️</div>`;

        row.innerHTML = `
          ${thumb}
          <div class="flex-1 min-w-0">
            <p class="text-text font-semibold text-sm truncate">${item.nombre}</p>
            <p class="text-brand text-xs font-bold mt-0.5">$${item.precio * item.cantidad}</p>
          </div>
          <div class="flex items-center gap-1 shrink-0 bg-border/30 rounded-xl p-1">
            <button class="qty-dec w-8 h-8 rounded-lg bg-white text-text font-bold text-xs flex items-center justify-center hover:bg-brand/10 active:scale-95 transition-all">−</button>
            <span class="qty-val w-6 text-center text-text font-bold text-sm">${item.cantidad}</span>
            <button class="qty-inc w-8 h-8 rounded-lg bg-brand text-white font-bold text-xs flex items-center justify-center hover:bg-brand-dark active:scale-95 transition-all">+</button>
          </div>
        `;
        row.querySelector('.qty-dec').addEventListener('click', () => decrementQuantity(item.nombre));
        row.querySelector('.qty-inc').addEventListener('click', () => incrementQuantity(item.nombre));
        itemsContainer.appendChild(row);
      } else {
        const qtyVal = row.querySelector('.qty-val');
        const priceEl = row.querySelector('.text-brand');
        if (qtyVal) qtyVal.textContent = item.cantidad;
        if (priceEl) priceEl.textContent = `$${item.precio * item.cantidad}`;
      }
    });
  }

  cartItems.subscribe(renderCartItems);

  totalPrice.subscribe((price) => {
    totalEl.textContent = `$${price}`;
    pillTotal.textContent = `$${price}`;
  });

  totalItems.subscribe((count) => {
    subtitle.textContent = `${count} ${count === 1 ? 'artículo' : 'artículos'}`;
  });

  let prevCount = 0;
  totalItems.subscribe((count) => {
    if (count === prevCount) return;
    prevCount = count;

    if (count > 0) {
      badge.textContent = count;
      badge.classList.remove('hidden');
      gsap.fromTo(
        badge,
        { scale: 0.5, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.35, ease: 'back.out(2)' }
      );
    } else {
      badge.classList.add('hidden');
    }
  });

  sendBtn.addEventListener('click', () => {
    const nombre = nameInput.value.trim();
    if (!nombre) {
      nameInput.classList.add('border-red-400', 'ring-2', 'ring-red-100');
      nameInput.focus();
      setTimeout(() => {
        nameInput.classList.remove('border-red-400', 'ring-2', 'ring-red-100');
      }, 2000);
      return;
    }

    const esDomicilio = deliveryCheckbox.checked;
    const direccion = addressInput.value.trim();
    if (esDomicilio && !direccion) {
      addressInput.classList.add('border-red-400', 'ring-2', 'ring-red-100');
      addressInput.focus();
      setTimeout(() => {
        addressInput.classList.remove('border-red-400', 'ring-2', 'ring-red-100');
      }, 2000);
      return;
    }

    const notas = notesInput.value.trim();
    const items = Object.values(cartItems.get());
    if (items.length === 0) return;

    let mensaje = `🛒 *Pedido Los Comales*%0A`;
    mensaje += `👤 *Nombre:* ${encodeURIComponent(nombre)}%0A`;
    if (esDomicilio) {
      mensaje += `🚚 *Servicio a domicilio*%0A`;
      mensaje += `📍 *Dirección:* ${encodeURIComponent(direccion)}%0A`;
    }
    if (notas) mensaje += `📝 *Notas:* ${encodeURIComponent(notas)}%0A`;
    mensaje += `%0A*Orden:*%0A`;
    items.forEach((item) => {
      mensaje += `- ${item.cantidad}x ${encodeURIComponent(item.nombre)} — $${item.precio * item.cantidad}%0A`;
    });
    mensaje += `%0A💰 *Total:* $${totalPrice.get()}`;

    window.open(`https://wa.me/529841918439?text=${mensaje}`, '_blank');
  });

  nameInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendBtn.click();
  });
</script>
