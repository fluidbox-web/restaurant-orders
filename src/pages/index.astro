---
import ProductCard from '../components/ProductCard.astro';
import ProductModal from '../components/ProductModal.astro';
import FloatingCart from '../components/FloatingCart.astro';
import menuData from '../data/menu.json';
import '../styles/global.css';

const { restaurante, menu } = menuData;
const categorias = Object.entries(menu);
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{restaurante.nombre} — Menú Digital</title>
    <meta name="description" content={restaurante.slogan} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Header -->
    <header
      id="site-header"
      class="fixed top-0 left-0 right-0 z-40 transition-all duration-300 text-white"
    >
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="#" class="font-display font-bold text-xl">{restaurante.nombre}</a>
        <a
          href="#menu"
          class="text-sm font-semibold px-4 py-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors"
        >
          Ver menú
        </a>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative min-h-[78vh] flex items-end md:items-center overflow-hidden">
      <img
        src="/assets/hero.jpg"
        alt={`Comida en ${restaurante.nombre}`}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-text/70 via-text/40 to-cream"></div>

      <div class="hero-content relative z-10 w-full max-w-6xl mx-auto px-4 pb-16 md:pb-0 md:text-center">
        <span
          class="inline-block text-white/90 text-xs md:text-sm font-semibold tracking-[0.25em] uppercase mb-4 md:mb-6"
        >
          Menú Digital
        </span>
        <h1
          class="font-display text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-4 md:mb-6 leading-[0.95] text-balance"
        >
          {restaurante.nombre}
        </h1>
        <p class="text-lg md:text-2xl text-white/90 mb-8 md:mb-10 font-light max-w-2xl md:mx-auto">
          {restaurante.slogan}
        </p>
        <a
          href="#menu"
          class="inline-flex items-center gap-2 bg-brand text-white px-8 py-4 rounded-full font-semibold text-base md:text-lg hover:bg-brand-dark transition-all shadow-2xl shadow-brand/30 hover:shadow-brand/40 hover:-translate-y-0.5"
        >
          Explorar menú
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M7 13l5 5 5-5"></path>
            <path d="M7 6l5 5 5-5"></path>
          </svg>
        </a>
      </div>
    </section>

    <!-- Category Tabs -->
    <div
      class="sticky top-14 z-30 bg-cream/95 backdrop-blur-md border-b border-border transition-shadow duration-300"
      id="tabs-bar"
    >
      <nav
        id="nav-tabs"
        class="max-w-6xl mx-auto px-4 py-3 flex gap-2 overflow-x-auto scrollbar-none"
      >
        {
          categorias.map(([nombre]) => (
            <button
              class="nav-tab whitespace-nowrap px-5 py-2.5 rounded-full text-sm font-semibold bg-white text-text border border-border hover:border-brand/30 hover:bg-brand/5 transition-all cursor-pointer shrink-0"
              data-target={nombre}
            >
              {nombre}
            </button>
          ))
        }
      </nav>
    </div>

    <!-- Menu -->
    <main id="menu" class="max-w-6xl mx-auto px-4 py-12 md:py-16">
      {
        categorias.map(([nombre, data]) => (
          <section id={nombre} class="mb-16 md:mb-24 scroll-mt-28">
            <!-- Category Header -->
            <div class="relative h-48 md:h-72 rounded-3xl overflow-hidden mb-6 md:mb-8 shadow-lg">
              <img
                src={data.imagen}
                alt={nombre}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-text/80 via-text/50 to-transparent" />
              <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10">
                <h2 class="font-display text-3xl md:text-5xl font-bold text-white mb-2 md:mb-3">
                  {nombre}
                </h2>
                {data.descripcion && (
                  <p class="text-white/85 text-sm md:text-base max-w-lg leading-relaxed">
                    {data.descripcion}
                  </p>
                )}
              </div>
            </div>

            <!-- Products Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
              {data.items.map((item) => (
                <ProductCard
                  nombre={item.nombre}
                  precio={item.precio}
                  descripcion={item.descripcion || ''}
                  imagen={item.imagen || data.imagen}
                  categoria={nombre}
                />
              ))}
            </div>
          </section>
        ))
      }
    </main>

    <!-- Footer -->
    <footer class="bg-text text-white/50 py-10 text-center text-sm">
      <p class="font-display text-lg text-white/90 mb-1">{restaurante.nombre}</p>
      <p>Menú Digital · Ordena fácil desde tu mesa</p>
    </footer>

    <FloatingCart />
    <ProductModal />

    <script>
      import gsap from 'gsap';

      const header = document.getElementById('site-header');
      const tabsBar = document.getElementById('tabs-bar');
      const headerLink = header.querySelector('a[href="#menu"]');

      function updateHeader() {
        const scrolled = window.scrollY > 60;
        if (scrolled) {
          header.classList.add('bg-cream/95', 'backdrop-blur-md', 'shadow-sm', 'text-text');
          header.classList.remove('text-white');
          headerLink.classList.remove('bg-white/10', 'hover:bg-white/20');
          headerLink.classList.add('bg-brand', 'text-white', 'hover:bg-brand-dark');
          tabsBar.classList.add('shadow-sm');
        } else {
          header.classList.remove('bg-cream/95', 'backdrop-blur-md', 'shadow-sm', 'text-text');
          header.classList.add('text-white');
          headerLink.classList.add('bg-white/10', 'hover:bg-white/20');
          headerLink.classList.remove('bg-brand', 'text-white', 'hover:bg-brand-dark');
          tabsBar.classList.remove('shadow-sm');
        }
      }

      window.addEventListener('scroll', updateHeader, { passive: true });
      updateHeader();

      // Category tabs smooth scroll
      const tabs = document.querySelectorAll('.nav-tab');
      const sections = [...document.querySelectorAll('section[id]')];

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = document.getElementById(tab.dataset.target);
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // Active tab via IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tabs.forEach((tab) => {
                const active = tab.dataset.target === entry.target.id;
                tab.classList.toggle('bg-brand', active);
                tab.classList.toggle('text-white', active);
                tab.classList.toggle('border-transparent', active);
                tab.classList.toggle('bg-white', !active);
                tab.classList.toggle('text-text', !active);
                tab.classList.toggle('border-border', !active);
              });
            }
          });
        },
        { rootMargin: '-35% 0px -55% 0px' }
      );

      sections.forEach((section) => observer.observe(section));

      // Hero entrance animation
      gsap.from('.hero-content > *', {
        y: 45,
        opacity: 0,
        duration: 0.9,
        stagger: 0.12,
        ease: 'power3.out',
        delay: 0.1,
      });

      // Stagger cards entrance using IntersectionObserver
      const cardObserver = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              gsap.fromTo(
                entry.target,
                { y: 30, opacity: 0 },
                { y: 0, opacity: 1, duration: 0.5, ease: 'power2.out' }
              );
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.product-card').forEach((card) => {
        gsap.set(card, { opacity: 0 });
        cardObserver.observe(card);
      });
    </script>

    <style is:global>
      .scrollbar-none {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
      .scrollbar-none::-webkit-scrollbar {
        display: none;
      }
    </style>
  </body>
</html>
